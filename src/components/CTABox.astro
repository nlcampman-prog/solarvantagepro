export interface Props { title: string; description: string; buttonLabel: string; buttonUrl: string; }
const { title, description, buttonLabel, buttonUrl } = Astro.props;
---
<div style="background:var(--color-surface);border:1px solid var(--color-primary);border-radius:12px;padding:1.5rem;margin:1.5rem 0;">
  <h3 style="margin:0 0 0.5rem;font-size:1.1rem;">{title}</h3>
  <p style="color:var(--color-text-secondary);font-size:0.9rem;margin-bottom:1rem;">{description}</p>
  <a href={buttonUrl} class="btn" rel="sponsored">{buttonLabel}</a>
</div>